# Cloudflare Tunnel URL (untuk akses gallery dari internet)
# 
# Cara setup:
# 1. Buka terminal baru di folder project
# 2. Jalankan: npx cloudflared tunnel --url http://localhost:3847
# 3. Copy URL yang muncul (misal: https://xxx-xxx.trycloudflare.com)
# 4. Paste di bawah ini
# 5. Restart aplikasi

VITE_TUNNEL_URL=

# Xendit Payment Gateway Secret Key
VITE_XENDIT_SECRET_KEY=

# Google Drive API Configuration (Mandiri)
VITE_GOOGLE_OAUTH_CLIENT_ID=
VITE_GOOGLE_OAUTH_CLIENT_SECRET=
VITE_GOOGLE_DRIVE_FOLDER_ID=
VITE_GOOGLE_DRIVE_REFRESH_TOKEN=