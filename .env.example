# Cloudflare Tunnel URL (untuk akses gallery dari internet)
# 
# Cara setup:
# 1. Buka terminal baru di folder project
# 2. Jalankan: npx cloudflared tunnel --url http://localhost:3847
# 3. Copy URL yang muncul (misal: https://xxx-xxx.trycloudflare.com)
# 4. Paste di bawah ini
# 5. Restart aplikasi

VITE_TUNNEL_URL=

# Gemini API (untuk fitur AI outfit swap - opsional)
VITE_GEMINI_API_KEY=

# Cloudinary (tidak digunakan jika pakai tunnel)
# VITE_CLOUDINARY_CLOUD_NAME=
# VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_KIE_AI_API_KEY=