{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ruarasa-booth",
  "version": "0.1.0",
  "identifier": "com.ivand.ruarasa-booth",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Inside Studio Photobox",
        "fullscreen": true,
        "resizable": true,
        "decorations": true,
        "alwaysOnTop": false,
        "width": 1920,
        "height": 1080
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' https: ws: http://127.0.0.1:* http://localhost:*; img-src 'self' https: data: blob: http://127.0.0.1:* http://localhost:*; media-src 'self' blob: mediastream:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
